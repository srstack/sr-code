#!/bin/sh
# Fake Claude Code CLI that emits one event then sleeps long enough for the
# test to cancel context. Used to verify SIGINT/WaitDelay handling.
cat >/dev/null
echo '{"type":"system","subtype":"init","cwd":"'"$PWD"'","session_id":"fake-slow"}'
sleep 30
echo '{"type":"result","subtype":"success","is_error":false,"result":"never","session_id":"fake-slow"}'
