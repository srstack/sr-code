#!/bin/sh
# Fake Claude Code CLI for sender tests.
# Reads (and ignores) stdin, then emits a few canned stream-json events
# resembling a successful turn.
cat >/dev/null
echo '{"type":"system","subtype":"init","cwd":"'"$PWD"'","session_id":"fake-session","tools":[]}'
echo '{"type":"stream_event","event":{"type":"content_block_delta","delta":{"type":"text_delta","text":"hello"}}}'
echo '{"type":"stream_event","event":{"type":"content_block_delta","delta":{"type":"text_delta","text":" world"}}}'
echo '{"type":"assistant","message":{"role":"assistant","content":[{"type":"text","text":"hello world"}]}}'
echo '{"type":"result","subtype":"success","is_error":false,"result":"hello world","session_id":"fake-session"}'
